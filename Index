<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Autobusowa przygoda 🚌</title>
    <style>
        * {
            box-sizing: border-box;
            user-select: none;
        }
        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(145deg, #1b4c2b, #0f3a1f);
            font-family: 'Segoe UI', system-ui, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .game-container {
            max-width: 1000px;
            width: 100%;
            background: #2e5e3a;
            border-radius: 48px 48px 24px 24px;
            box-shadow: 0 20px 30px rgba(0,0,0,0.6);
            padding: 30px 25px;
            border-bottom: 8px solid #5f8b4b;
        }
        .bus-panel {
            background: #f5e1a0;
            border-radius: 60px 60px 30px 30px;
            padding: 25px 30px;
            box-shadow: inset 0 -8px 0 #b68b40, inset 0 2px 10px #ffeeaa;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 30px;
            border: 4px solid #846f3a;
        }
        .bus-icon {
            font-size: 68px;
            filter: drop-shadow(8px 12px 0 #5e3a1e);
        }
        .stats {
            background: #2e261a;
            padding: 12px 25px;
            border-radius: 50px;
            color: #feda7a;
            font-weight: bold;
            font-size: 26px;
            letter-spacing: 2px;
            box-shadow: inset 0 -3px 0 #5e4c2b, inset 0 2px 8px #ffd966;
        }
        .garage {
            background: #5b4b3a;
            border-radius: 30px;
            padding: 20px;
            margin-bottom: 25px;
            border: 6px solid #94805c;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            color: #ffe5a3;
        }
        .upgrade-btn {
            background: #fecc6f;
            border: none;
            border-radius: 40px;
            padding: 14px 28px;
            font-size: 22px;
            font-weight: bold;
            color: #2d3810;
            border-bottom: 8px solid #a0813f;
            transition: 0.06s;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .upgrade-btn:active {
            border-bottom-width: 3px;
            transform: translateY(5px);
        }
        .upgrade-btn:disabled {
            opacity: 0.5;
            border-bottom-width: 8px;
            transform: none;
            pointer-events: none;
        }
        .route-layer {
            background: #3e6b4b;
            border-radius: 40px 40px 20px 20px;
            padding: 25px 20px;
            border: 6px solid #bed37e;
        }
        .stop-list {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }
        .stop-card {
            background: #b3d9b0;
            border-radius: 30px;
            padding: 18px 28px;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            border-bottom: 10px solid #5e914f;
            box-shadow: 0 6px 0 #365e2b;
            color: #1e3a1e;
            font-size: 22px;
            font-weight: 600;
        }
        .stop-card.locked {
            background: #7f8c7a;
            border-bottom-color: #4e5a49;
            box-shadow: 0 6px 0 #2e3a2b;
            color: #d4cfb0;
            filter: grayscale(0.6);
        }
        .passenger-badge {
            background: #162012;
            padding: 12px 18px;
            border-radius: 50px;
            color: #fff3c9;
            font-size: 26px;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .collect-btn {
            background: #ffbe5e;
            border: none;
            font-size: 26px;
            padding: 12px 28px;
            border-radius: 60px;
            border-bottom: 8px solid #b4722a;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: 0.04s;
        }
        .collect-btn:active {
            border-bottom-width: 3px;
            transform: translateY(5px);
        }
        .collect-btn:disabled {
            opacity: 0.4;
            border-bottom-width: 8px;
            transform: none;
        }
        .money-effect {
            color: #ffd966;
            text-shadow: 2px 2px 0 #3a4a1e;
        }
        h2 {
            color: #fbffb4;
            font-size: 32px;
            margin: 0 0 12px 0;
            text-shadow: 4px 4px 0 #3f602b;
        }
    </style>
</head>
<body>
<div class="game-container">
    <!-- AUTOBUS I KASA -->
    <div class="bus-panel">
        <span class="bus-icon">🚌</span>
        <div class="stats">
            💰 <span id="cashDisplay">300</span>
        </div>
        <span style="font-size:30px; background:#af7a41; padding:12px; border-radius:30px;">👥 <span id="passengersCollected">0</span></span>
    </div>

    <!-- GARAŻ / ROZWÓJ AUTOBUSU -->
    <div class="garage">
        <span style="font-size:30px;">🔧 <span id="busLevelName">Autobus Miejski</span></span>
        <div style="display:flex; gap:15px;">
            <button id="upgradeCapacityBtn" class="upgrade-btn">➕ Miejsca (200💰)</button>
            <button id="upgradeLookBtn" class="upgrade-btn">✨ Ładniejszy (300💰)</button>
        </div>
    </div>

    <!-- LISTA PRZYSTANKÓW -->
    <div class="route-layer">
        <h2>🚏 TRASA</h2>
        <div id="stopContainer" class="stop-list"></div>
    </div>
</div>

<script>
    (function() {
        // ----- STAN GRY -----
        let cash = 300;               // startowa kasa
        let totalPassengers = 0;      // ile ludzi łącznie zebranych
        let busCapacity = 8;          // początkowa pojemność (miejsca)
        let busLookLevel = 1;         // 1 = zwykły, 2 = ładny, 3+ = luksus

        // Definicje przystanków
        let stops = [
            { id: 0, name: "Pętla Główna", passengers: 4, locked: false, basePayout: 15, route: "Linia 1" },
            { id: 1, name: "Rynek", passengers: 7, locked: false, basePayout: 25, route: "Linia 1" },
            { id: 2, name: "Dworzec", passengers: 9, locked: true, basePayout: 45, route: "Linia 2" },
            { id: 3, name: "Osiedle Kwiatowe", passengers: 12, locked: true, basePayout: 70, route: "Linia 2" },
            { id: 4, name: "Plac Wolności", passengers: 15, locked: true, basePayout: 100, route: "Linia 3" },
            { id: 5, name: "Stadion", passengers: 20, locked: true, basePayout: 150, route: "Linia 3" },
            { id: 6, name: "Lotnisko", passengers: 28, locked: true, basePayout: 230, route: "Linia 4" }
        ];

        // koszty odblokowania przystanku (indeks)
        const UNLOCK_COSTS = [0, 0, 200, 280, 400, 550, 750];
        // ceny ulepszeń
        const CAPACITY_UPGRADE_COST = 200;
        const LOOK_UPGRADE_COST = 300;

        // ----- Elementy DOM -----
        const cashDisplay = document.getElementById('cashDisplay');
        const passengersCollectedSpan = document.getElementById('passengersCollected');
        const busLevelName = document.getElementById('busLevelName');
        const stopContainer = document.getElementById('stopContainer');
        const upgradeCapacityBtn = document.getElementById('upgradeCapacityBtn');
        const upgradeLookBtn = document.getElementById('upgradeLookBtn');

        // ----- FUNKCJE POMOCNICZE -----
        function updateUI() {
            // odświeżenie kasy i pasażerów
            cashDisplay.textContent = cash;
            passengersCollectedSpan.textContent = totalPassengers;

            // nazwy autobusu od wyglądu
            if (busLookLevel === 1) busLevelName.textContent = 'Autobus Miejski';
            else if (busLookLevel === 2) busLevelName.textContent = 'Srebrny Autokar';
            else if (busLookLevel === 3) busLevelName.textContent = 'Złoty Autobus';
            else busLevelName.textContent = '✨ Super Lumina ✨';

            // blokowanie przycisków ulepszeń jeśli brak kasy
            upgradeCapacityBtn.disabled = (cash < CAPACITY_UPGRADE_COST);
            upgradeLookBtn.disabled = (cash < LOOK_UPGRADE_COST);
        }

        // generowanie listy przystanków
        function renderStops() {
            let html = '';
            stops.forEach((stop, index) => {
                // ile pasażerów do zabrania (zwiększa się z pojemością i wyglądem?)
                let passCount = stop.passengers;
                // dodatkowi pasażerowie gdy autobus ładniejszy – frajda!
                if (!stop.locked) {
                    if (busLookLevel >= 2) passCount = Math.floor(passCount * 1.2);  // +20%
                    if (busLookLevel >= 3) passCount = Math.floor(passCount * 1.3);  // więcej
                    if (busLookLevel >= 4) passCount = Math.floor(passCount * 1.5);
                }
                // zablokowany przystanek wygląda inaczej
                const lockedClass = stop.locked ? 'locked' : '';
                const disabledAttr = stop.locked ? 'disabled' : '';

                // ile kasy da za zebranie
                let payout = Math.floor(stop.basePayout * (1 + (busLookLevel * 0.1)));
                if (stop.locked) payout = 0;

                // przycisk odblokowania (tylko jeśli zablokowany i stać)
                let unlockButton = '';
                if (stop.locked) {
                    const cost = UNLOCK_COSTS[index] || 999;
                    const canAfford = cash >= cost;
                    unlockButton = `<button class="upgrade-btn" style="font-size:20px; padding:10px 24px;" 
                        onclick="window.gameInterop.unlockStop(${index})" ${!canAfford ? 'disabled' : ''}>
                        🔓 Odblokuj (${cost}💰)
                    </button>`;
                }

                // główna karta przystanku
                html += `<div class="stop-card ${lockedClass}">
                    <div style="display:flex; flex-direction:column; gap:4px;">
                        <span style="font-size:28px;">🚏 ${stop.name}</span>
                        <span style="font-size:18px; opacity:0.9;">${stop.route}</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:20px; flex-wrap:wrap;">
                        ${!stop.locked ? 
                            `<span class="passenger-badge">👥 ${passCount} · 💰 ${payout}</span>
                             <button class="collect-btn" onclick="window.gameInterop.collectPassengers(${index}, ${passCount}, ${payout})"
                                ${busCapacity < passCount ? 'disabled' : ''}>
                                🚌 Zabierz
                             </button>` 
                            : 
                            `<span style="font-size:26px;">🔒 Zablokowany</span>
                             ${unlockButton}`
                        }
                    </div>
                </div>`;
            });
            stopContainer.innerHTML = html;
        }

        // ----- GŁÓWNE AKCJE -----
        function collectPassengers(stopIndex, passCount, payout) {
            const stop = stops[stopIndex];
            if (stop.locked) {
                alert('Przystanek zablokowany!');
                return;
            }
            if (busCapacity < passCount) {
                alert(`Za mało miejsc w autobusie! (masz ${busCapacity}, potrzebujesz ${passCount})`);
                return;
            }
            // zabieramy pasażerów
            totalPassengers += passCount;
            cash += payout;

            // aktualizujemy stan gry
            updateUI();
            renderStops();  // odśwież listę, bo odblokowania, ilość pasażerów zależy od look level
        }

        function unlockStop(stopIndex) {
            const stop = stops[stopIndex];
            if (!stop.locked) return;
            const cost = UNLOCK_COSTS[stopIndex] || 0;
            if (cash >= cost) {
                cash -= cost;
                stop.locked = false;
                updateUI();
                renderStops();
            } else {
                alert('Za mało pieniędzy!');
            }
        }

        // rozwijanie autobusu
        function upgradeCapacity() {
            if (cash >= CAPACITY_UPGRADE_COST) {
                cash -= CAPACITY_UPGRADE_COST;
                busCapacity += 6;   // +6 miejsc
                updateUI();
                renderStops();   // przystanki mogą wymagać więcej miejsc
            }
        }

        function upgradeLook() {
            if (cash >= LOOK_UPGRADE_COST) {
                cash -= LOOK_UPGRADE_COST;
                busLookLevel = Math.min(busLookLevel + 1, 5);  // max poziom 5
                updateUI();
                renderStops();   // odświeżenie – zmienia się liczba pasażerów i payout
            }
        }

        // interop z przyciskami (żeby działały z onclick w generowanym HTML)
        window.gameInterop = {
            collectPassengers: (stopIndex, passCount, payout) => collectPassengers(stopIndex, passCount, payout),
            unlockStop: (stopIndex) => unlockStop(stopIndex)
        };

        // przypisanie eventów do ulepszeń
        upgradeCapacityBtn.addEventListener('click', upgradeCapacity);
        upgradeLookBtn.addEventListener('click', upgradeLook);

        // start gry
        function initGame() {
            updateUI();
            renderStops();
        }
        initGame();
    })();
</script>
</body>
</html>
