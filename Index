<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>System Kompletacji Paczek</title>

<style>
body{
font-family: Arial;
background:#f4f6f8;
text-align:center;
padding:30px;
}

h1{
color:#333;
}

.box{
background:white;
padding:20px;
margin:20px auto;
max-width:600px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,0.1);
}

input{
width:80%;
padding:15px;
font-size:18px;
margin-top:10px;
}

ul{
list-style:none;
padding:0;
}

li{
padding:10px;
margin:5px;
font-size:18px;
border-radius:5px;
background:#eee;
}

.done{
background:#9be79b;
}

.status{
font-size:20px;
margin-top:20px;
font-weight:bold;
}

.error{
color:red;
}

.success{
color:green;
}
</style>

</head>
<body>

<h1>📦 System kompletacji paczek</h1>

<div class="box">
<h2>Skanuj list przewozowy</h2>
<input id="packageInput" placeholder="Zeskanuj list..." autofocus>
</div>

<div class="box">
<h2>Produkty w paczce</h2>
<ul id="productList"></ul>
</div>

<div class="box">
<h2>Skanuj produkt</h2>
<input id="productInput" placeholder="Zeskanuj produkt...">
<div class="status" id="status">Oczekiwanie na skan...</div>
</div>

<script>

const orders = {

"DPD123": [
"DPD999": [
{name:"Aloe Vera Gel ", code:"8720359200198", qty:2, picked:0},
{name:"Produkt B", code:"5908888888888", qty:5, picked:0}
]

"DPD456": [
{name:"Bluza", code:"5904444444444", qty:1, picked:0},
{name:"Skarpety", code:"5905555555555", qty:5, picked:0}
]

};

let currentOrder = null;

const packageInput = document.getElementById("packageInput");
const productInput = document.getElementById("productInput");
const productList = document.getElementById("productList");
const status = document.getElementById("status");

packageInput.addEventListener("change", () => {

const code = packageInput.value.trim();

if(!orders[code]){

status.innerHTML="❌ Nie znaleziono paczki";
status.className="status error";
return;

}

currentOrder = JSON.parse(JSON.stringify(orders[code]));
renderProducts();

status.innerHTML="✅ Paczka załadowana";
status.className="status success";

packageInput.value="";
productInput.focus();

});

productInput.addEventListener("change", () => {

if(!currentOrder) return;

const scan = productInput.value.trim();
let found = false;

currentOrder.forEach(p => {

if(p.code === scan && p.picked < p.qty){

p.picked++;
found = true;

}

});

if(!found){

status.innerHTML="❌ Produkt nie należy do tej paczki";
status.className="status error";

}else{

status.innerHTML="✅ Produkt zeskanowany";
status.className="status success";

}

renderProducts();
checkFinished();

productInput.value="";

});

function renderProducts(){

productList.innerHTML="";

currentOrder.forEach(p => {

let li = document.createElement("li");

li.textContent = p.name + " ("+p.picked+"/"+p.qty+")";

if(p.picked === p.qty){
li.classList.add("done");
}

productList.appendChild(li);

});

}

function checkFinished(){

let done = currentOrder.every(p => p.picked === p.qty);

if(done){

status.innerHTML="🎉 Paczka skompletowana";
status.className="status success";

}

}

</script>

</body>
</html>
